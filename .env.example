# OpenRouter API Key
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here

# Stripe (server-side secret — never use REACT_APP_ prefix for this)
STRIPE_SECRET_KEY=
# Stripe Price ID — set in Netlify dashboard as both STRIPE_PRICE_ID (functions) and REACT_APP_STRIPE_PRICE_ID (frontend)
REACT_APP_STRIPE_PRICE_ID=
